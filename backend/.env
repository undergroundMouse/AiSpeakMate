APP_NAME=AiSpeakMate
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aispeakmate
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# LLM — DeepSeek (国内可直接访问，¥1/百万token)
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_MODEL=deepseek-chat
# Legacy Groq keys (ignored when LLM_PROVIDER is set)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
SPEECHSUPER_API_KEY=
SPEECHSUPER_ENDPOINT=https://api.speechsuper.com
